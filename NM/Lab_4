#6
def RR(h):
    return approximation(h) + ((approximation(h) - approximation(h * 2)) / 3)


def R2(h):
    return abs(RR(h) - derivative(x0))

R2_mas = []
for hi in h_mas:
    R2_mas.append(R2(hi))


print(f"Runge-Romberg: {RR(h)}")
print(f"Approximation error for RR: {R2(h)}")


plt.loglog(h_mas, R2_mas)
plt.grid()
plt.xlabel('h')
plt.ylabel('R2')
plt.show()

#7
def yE(h):
    return (approximation(h * 2) ** 2 - approximation(h * 4) * approximation(h)) / (2 * approximation(h * 2) - (approximation(h * 4) + approximation(h)))

p = 1 / m.log(2) * m.log(abs((approximation(h * 4) - approximation(h * 2)) / (approximation(h * 2) - approximation(h))))

def R3(h):
    return abs(yE(h) - derivative(x0))

print(f"Eitkein method: {yE(h)}")
print(f"Order of precision: {p}")
print(f"Approximation error for Eitkein: {R3(h)}")


R3_mas = []
for item in h_mas:
    R3_mas.append(R3(item))


plt.loglog(h_mas, R3_mas)
plt.grid()
plt.xlabel('h')
plt.ylabel('R3')
plt.show()


