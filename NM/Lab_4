import numpy as np
import matplotlib.pyplot as plt
import math as m

def func(x):
    return 50 * m.exp(-0.1 * x) + 5 * m.sin(x)
def approximation(h):
    return (func(x0 + h) - func(x0 - h)) / (2 * h)
def derivative(t):
    return -5 * m.exp(-0.1 * t) + 5 * m.cos(t)
def R_calc(h, x):
    return abs(approximation(h) - derivative(x))

x0 = 5
h = 10 ** -3
y = []
t = np.linspace(0, 20, 1000)
h_mas = np.logspace(-20, 3, 230)
R_mas = []
for x in t:
    y.append(func(x))

for i in h_mas:
    R_mas.append(R_calc(i, x0))

print("first derivative(x0):",derivative(x0))
print("Approximation:",approximation(h))
# numerical differention error
#print('NDE:',R)
plt.plot(t, y)
plt.grid()
plt.xlabel('t')
plt.ylabel('M(t)')
plt.title("Soil Moisture Model M(t)")
plt.show()


plt.loglog(h_mas, R_mas)
plt.grid()
plt.xlabel('h')
plt.ylabel('R')
plt.show()


idx_min = np.argmin(R_mas)

h0 = h_mas[idx_min]
R0 = R_mas[idx_min]

print(f"Best precision with: {h0:.0e}")
print(f"Precision for best h: {R0}")

